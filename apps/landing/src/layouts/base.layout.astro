---
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="My Org — The modern SaaS platform" />
    <title>{title}</title>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body { font-family: system-ui, -apple-system, sans-serif; line-height: 1.6; color: #333; }
      a { color: inherit; }
    </style>
  </head>
  <body>
    <header style="padding: 1rem 2rem; border-bottom: 1px solid #eee; display: flex; justify-content: space-between; align-items: center;">
      <strong>My Org</strong>
      <nav style="display: flex; gap: 1.5rem;">
        <a href="/">Home</a>
        <a href="/login">Sign In</a>
      </nav>
    </header>
    <slot />
    <footer style="padding: 2rem; text-align: center; border-top: 1px solid #eee; color: #999; margin-top: 4rem;">
      &copy; {new Date().getFullYear()} My Org. All rights reserved.
    </footer>
  </body>
</html>
